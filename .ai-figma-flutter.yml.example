# Agent configuration — copy to `.ai-figma-flutter.yml` in the figma-flutter-agent repo root.
# LLM provider, models, sampling, reasoning: `.env` only — see `.env.example`.
# This file: codegen policy (when/how LLM runs, repair/refine loops, gates).
# Production gates: CLI applies them on `generate` (non-dry-run) — use `--allow-dev-profile` locally.
# Visual QA: enable dark_mode / validation block below, or `demo-signoff --visual-qa`.

# --- Theme & project shape ---
theme:
  variant: material_3  # material_3 | cupertino
  generate: true

flutter:
  architecture: feature_first  # feature_first | layer_first

dark_mode:
  enabled: false  # true for visual QA / dark theme codegen

# --- Layout & responsive ---
responsive:
  mode: responsive  # static | responsive | both (dual Chrome; logs on responsive only)
  require_reflow: false  # true: fail when layout tier is scaled/fixed instead of reflowed
  max_web_width: 1200
  adaptive_render: false  # legacy; launch mode is controlled by responsive.mode
  preview_width: 390  # fallback when no dump; dump frame size wins when present
  preview_height: 844
  macro_height_threshold_px: 900  # root extent above this triggers NAV_SCROLL_HOST

layout:
  avoid_fixed_sizes: true
  use_scaffold: true
  snap_device_pixels: false  # FID-45: snap Positioned coords to physical pixels (opt-in)

layout_passes:
  inject_root_scroll_host: true
  scroll_extent_fallback_threshold_px: null  # null → responsive.macro_height_threshold_px

quality:
  enforce_spec9_gates: false
  max_layout_depth: 8
  strict_accessibility_labels: false
  strict_contrast: false
  fail_duplicate_clusters: false

accessibility:
  auto_fix: true  # production profile sets false (fail on contrast instead of auto-fix)

semantics:
  enabled: true
  report_only: true
  confidence_threshold: 0.8

# --- Generation (IR + repair/refine; not LLM model env) ---
generation:
  use_geometry_planner: true
  pixel_fidelity: false
  use_screen_ir: true  # LLM emits screenIr + extractedWidgets.widgetIr
  require_screen_ir: true  # IR-only: no screenCode from model
  allow_destination_stubs: false
  enforce_cluster_widgets: true
  cluster_min_count: 2
  true_subtree_pruning: true
  use_package_imports: true
  regen_llm_on_token_change: true
  llm_figma_reference_image: true
  llm_repair_after_analyze: true
  llm_repair_max_attempts: 4
  llm_repair_include_figma_png: false
  llm_repair_cpi_supervisor: true
  llm_repair_prompt_escalation: true
  llm_visual_refine: false
  llm_visual_refine_max_attempts: 2
  llm_visual_refine_threshold: 0.005
  llm_visual_refine_capture_golden: false
  golden_capture_timeout_sec: 600
  text_coordinate_tolerance: 3
  runtime_geometry_gate: true
  runtime_geometry_use_tier_thresholds: true
  runtime_geometry_tier_canvas: 0.99
  runtime_geometry_tier_structural: 0.95
  runtime_geometry_tier_component: 0.90
  runtime_geometry_tier_leaf: 0.82
  runtime_geometry_min_iou: 0.95
  runtime_geometry_capture_if_missing: false

state_management:
  type: none  # none | riverpod | bloc | provider

routing:
  type: none  # none | go_router | auto_route | navigator2
  generate_destinations: true

naming:
  widget_suffix: Widget
  feature_name: auto

sync:
  enabled: true
  fail_on_corrupt_snapshot: false

# --- UX reports (optional) ---
ux:
  suggestions: true
  write_report: true
  design_coverage: false

animations:
  write_manifest: true

dev:
  design_gallery: false
  debug_capture: false  # capture PNG under .debug; Figma gold in reference/figma

# --- Assets & fonts ---
assets:
  svg: true
  png_scales: [1, 2, 3]
  webp: false
  illustrations: true
  optimize: true
  images_batch_delay_sec: 1.0

fonts:
  enabled: true
  download_fonts: false
  skip_system_fallback: true
  cache_enabled: true

# --- Host runtime (golden capture, AST sidecar) ---
runtime:
  golden_capture: auto  # auto | docker | host — override with FIGMA_GOLDEN_RUNTIME in .env
  default_capture_mode: preview  # preview: Flutter web PNG | oracle: + Figma diff
  flutter_device_id: auto  # chrome, windows, …; auto prefers Chrome when listed
  use_ast_sidecar: true
  cleanup_stale_processes_on_start: true
  quiet_expected_warnings: true

# --- Validation & analyze gates ---
validation:
  export_figma_reference: false
  generate_golden_test: false
  generate_typography_specimen_test: false
  reference_scale: 2.0
  pixel_diff_threshold: 0.05
  require_dart_sdk: false
  spec23_dart_analyze: false
  emit_parse_gate: false
  analyze_scope: all_planned  # written_only | all_planned | project
  strict_preservation: false

# --- Figma API / Dev Mode CSS dump ---
figma:
  style_metadata:
    source: rest_synthesis  # rest_synthesis | hybrid | dev_mode_inspect
  dev_mode:
    enabled: false
    dev_resources:
      fetch_on_sync: false
    inspect_css:
      mode: off  # off | plugin_dump
      # dump_path: dumps/my_screen.json  # required when mode == plugin_dump
