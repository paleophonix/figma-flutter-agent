{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "figma-flutter — interactive menu",
      "type": "debugpy",
      "request": "launch",
      "module": "figma_flutter_agent.cli",
      "args": ["-i"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "Flutter: demo_app (chrome)",
      "type": "dart",
      "request": "launch",
      "program": "lib/main.dart",
      "cwd": "${workspaceFolder}/../demo_app",
      "deviceId": "chrome"
    },
    {
      "name": "Flutter: demo_app (select device)",
      "type": "dart",
      "request": "launch",
      "program": "lib/main.dart",
      "cwd": "${workspaceFolder}/../demo_app"
    }
  ]
}
