{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "figma-flutter: menu",
      "type": "shell",
      "command": "poetry run figma-flutter -i",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true
      },
      "problemMatcher": []
    }
  ]
}
