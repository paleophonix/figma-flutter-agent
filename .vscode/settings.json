{
  "python.terminal.activateEnvironment": false,
  "VsCodeTaskButtons.showCounter": false,
  "VsCodeTaskButtons.tasks": [
    {
      "label": "$(play) figma-flutter",
      "task": "figma-flutter: menu",
      "tooltip": "Interactive menu (poetry run figma-flutter -i)"
    },
    {
      "label": "$(beaker) pytest",
      "task": "pytest: all (offline)",
      "tooltip": "All offline tests (poetry run pytest -q -m \"not live_figma\")"
    }
  ],
  "dart.projectSearchDepth": 6,
  "dart.analysisExcludedFolders": [
    "src/figma_flutter_agent/generator/templates",
    "tests/fixtures/dart",
    "tests/fixtures/flutter_skeleton/lib/harness",
    "logs"
  ],
  "python.analysis.exclude": [
    "**/logs/**"
  ],
  "files.watcherExclude": {
    "**/logs/**": true
  },
  "python.testing.pytestArgs": [
    "tests"
  ],
  "python.testing.unittestEnabled": false,
  "python.testing.pytestEnabled": true
}