# =============================================================================
# Figma API
# =============================================================================
FIGMA_ACCESS_TOKEN=figd_your_personal_access_token

# =============================================================================
# Flutter workspace (agent .env only — not in YAML)
# =============================================================================
# Parent folder with multiple apps (demo_app/, my_app/, …) or a single app root.
# Active app: wizard menu → switch (persisted under <workspace>/.figma-flutter/workspace-state.yml)
# FIGMA_FLUTTER_PROJECT_DIR=E:/@dev

# Flutter SDK when `flutter` is not on PATH (same as VS Code dart.flutterSdkPath)
# FIGMA_FLUTTER_SDK=C:/src/flutter

# =============================================================================
# Agent behavior YAML (repo root — not env)
# =============================================================================
# Copy `.ai-figma-flutter.yml.example` → `.ai-figma-flutter.yml`
# Control panel: copy `.control-panel.yml.example` → `.control-panel.yml`

# =============================================================================
# Figma smoke / wizard defaults
# =============================================================================
# live-check / pytest -m live_figma — node-id 1-2 in URL → FIGMA_SMOKE_NODE_ID=1:2
FIGMA_SMOKE_FILE_KEY=
FIGMA_SMOKE_NODE_ID=

# Optional default Figma URL for wizard prompts (after screens.yaml)
# FIGMA_DEFAULT_URL=https://www.figma.com/design/<FILE_KEY>/...?node-id=1-2

# =============================================================================
# LLM provider & models (.env only — not in YAML)
# =============================================================================
# anthropic | openai | openrouter | google | google_aistudio
LLM_PROVIDER=anthropic

LLM_GENERATE_MODEL=
LLM_GENERATE_MODEL_2=
LLM_GENERATE_MODEL_3=
LLM_REPAIR_MODEL=
LLM_REFINE_MODEL=

# =============================================================================
# LLM sampling & retries
# =============================================================================
LLM_TEMPERATURE=1
LLM_REPAIR_TEMPERATURE=0.2
LLM_TOP_P=1
LLM_REQUIRE_STRICT_JSON_SCHEMA=false
LLM_MAX_RETRIES=3
# LLM_MAX_OUTPUT_TOKENS=16384

# =============================================================================
# LLM reasoning (optional — generate/refine; repair never uses reasoning)
# =============================================================================
# effort: none | minimal | low | medium | high | xhigh
# LLM_REASONING_EFFORT=medium
# LLM_REASONING_MAX_TOKENS=
# LLM_REASONING_EXCLUDE=true

# =============================================================================
# LLM API keys (set the key for your LLM_PROVIDER)
# =============================================================================
ANTHROPIC_API_KEY=sk-ant-your_api_key
GOOGLE_API_KEY=your_google_ai_studio_api_key
OPENAI_API_KEY=sk-your_openai_api_key
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_api_key

# =============================================================================
# Golden capture & AST sidecar (optional overrides)
# =============================================================================
# FIGMA_GOLDEN_RUNTIME=host
# FIGMA_GOLDEN_CAPTURE_TIMINGS=1
# FIGMA_GOLDEN_CAPTURE_AUTO_BUILD=1
# FIGMA_AST_COMPILER_PATH=
# FIGMA_FLUTTER_SKIP_STALE_CLEANUP=1

# =============================================================================
# Observability — PostHog LLM analytics (optional)
# =============================================================================
# POSTHOG_API_KEY=phc_your_project_api_key
# POSTHOG_HOST=https://us.i.posthog.com
# POSTHOG_CAPTURE_MAX_ATTEMPTS=3
# POSTHOG_CAPTURE_TIMEOUT_SEC=8
# POSTHOG_CAPTURE_RETRY_BASE_SEC=0.75

# =============================================================================
# Observability — Grafana Loki (optional)
# =============================================================================
# LOKI_ENABLED=false
# LOKI_URL=https://logs-prod-xxx.grafana.net/loki/api/v1/push
# LOKI_USER=123456
# LOKI_API_KEY=glc_xxx
# LOKI_LABELS=team=appfox,app=figma-flutter-agent
# LOKI_BATCH_SIZE=64
# LOKI_FLUSH_INTERVAL_SEC=2
# LOKI_PUSH_MAX_ATTEMPTS=3
# LOKI_PUSH_TIMEOUT_SEC=8
# LOKI_PUSH_RETRY_BASE_SEC=0.75

# =============================================================================
# Control panel — Discord / Postgres / Redis / public API (optional)
# =============================================================================
# DISCORD_BOT_TOKEN=
# GITLAB_PRIVATE_TOKEN=
# GITHUB_TOKEN=
#
# Database — bundled (Docker profile bundled-db) or external:
#   bundled:  database.mode=bundled in .control-panel.yml + FIGMA_CP_PG_PASSWORD
#   external: database.mode=external + database.url, or FIGMA_CP_DATABASE_URL
# FIGMA_CP_DATABASE_MODE=bundled
# FIGMA_CP_PG_PASSWORD=figma_cp_dev
# FIGMA_CP_DATABASE_URL=
# FIGMA_CP_PGDATA=./.data/postgres
# Host app → Docker Postgres: database.bundled_host: 127.0.0.1 in .control-panel.yml
#
# FIGMA_CP_REDIS_URL=redis://127.0.0.1:6379/0
# FIGMA_CP_INTERNAL_URL=https://your-public-host.example.com  # overrides yaml control_panel_url (webhooks/Telegram); use ngrok HTTPS here for GitLab
# CONTROL_PANEL_CONFIG=
# DISCORD_BOT_INTERNAL_SECRET=
# CONTROL_PANEL_GITLAB_WEBHOOK_SECRET=
# DISCORD_BOT_GITLAB_WEBHOOK_SECRET=  # legacy alias
# DISCORD_BOT_GITHUB_WEBHOOK_SECRET=
#
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_WEBHOOK_SECRET=
#
# CONTROL_PANEL_API_ENABLED=1
# CONTROL_PANEL_API_CLIENTS=[{"principal":"ci-bot","key_hash":"<sha256>","project_key":"default","active_repo_key":"mobile-app"}]
# CONTROL_PANEL_RATE_LIMIT_JOBS_PER_MIN=10
# CONTROL_PANEL_RATE_LIMIT_JOBS_GLOBAL_PER_MIN=50
# CONTROL_PANEL_METRICS_TOKEN=
