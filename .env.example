FIGMA_ACCESS_TOKEN=figd_your_personal_access_token

# Default Flutter project when --project-dir is omitted (agent repo .env only; not in YAML)
# FIGMA_FLUTTER_PROJECT_DIR=E:/@dev/demo_app

# Flutter SDK root when `flutter` is not on PATH (common with VS Code tasks on Windows).
# Same path as VS Code "dart.flutterSdkPath" — folder that contains bin/flutter.bat
# FIGMA_FLUTTER_SDK=C:/src/flutter

# Optional: live-check + pytest -m live_figma (frame from your design URL)
# One-shot (prints values to paste below):
#   poetry run figma-flutter live-check --figma-url "https://www.figma.com/design/<FILE_KEY>/...?node-id=1-2"
# URL node-id 1-2 -> FIGMA_SMOKE_NODE_ID=1:2 (colon, not hyphen)
FIGMA_SMOKE_FILE_KEY=
FIGMA_SMOKE_NODE_ID=

# Optional default Figma URL for wizard prompts (file link or frame link with node-id).
# Falls back after screens.yaml; Enter accepts the shown default.
# FIGMA_DEFAULT_URL=https://www.figma.com/design/<FILE_KEY>/...?node-id=1-2

# Agent behavior YAML lives in the figma-flutter-agent repo (`.ai-figma-flutter.yml`).
# Copy from `.ai-figma-flutter.yml.example` on first setup — not in the Flutter project.

# Active LLM provider: anthropic | openai | openrouter | google
LLM_PROVIDER=anthropic

# Model IDs (optional; else provider default). Repair/refine inherit generate when unset.
# Any OpenRouter/Anthropic/OpenAI model slug works; repair never sends reasoning knobs.
# LLM_GENERATE_MODEL=claude-sonnet-4-6 | gpt-4.1-mini | google/gemini-3.5-flash
# LLM_REPAIR_MODEL=   # optional override; defaults to LLM_GENERATE_MODEL
# LLM_REFINE_MODEL=
LLM_GENERATE_MODEL=
LLM_REPAIR_MODEL=
LLM_REFINE_MODEL=

# Sampling and structured output (technical LLM params — not in YAML)
LLM_TEMPERATURE=0
LLM_TOP_P=1
LLM_REQUIRE_STRICT_JSON_SCHEMA=false
# Transient API failures (429/5xx, invalid JSON); default 3
LLM_MAX_RETRIES=3

# Optional reasoning/thinking for generate/refine only (repair ignores these for compatibility).
# Invalid values are dropped. On timeout or provider rejection, generate retries without reasoning.
# effort: none | minimal | low | medium | high | xhigh — omit to use provider default
# max_tokens: Anthropic/Gemini 2.5-style budget; do not set both effort and max_tokens
# exclude: true hides reasoning tokens from the response (model may still reason)
# LLM_REASONING_EFFORT=medium
# LLM_REASONING_MAX_TOKENS=
# LLM_REASONING_EXCLUDE=true

ANTHROPIC_API_KEY=sk-ant-your_api_key
GOOGLE_API_KEY=sk-your_google_api_key
OPENAI_API_KEY=sk-your_openai_api_key
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_api_key

# Optional PostHog LLM analytics (one $ai_trace_id per run; spans: generate, repair, refine)
# POSTHOG_API_KEY=phc_your_project_api_key
# POSTHOG_HOST=https://us.i.posthog.com
