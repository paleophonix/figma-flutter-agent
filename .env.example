FIGMA_ACCESS_TOKEN=figd_your_personal_access_token

# Flutter workspace root when --project-dir is omitted (agent .env only; not in YAML).
# Parent folder with multiple apps (demo_app/, my_app/, …) or a single app root.
# Active app: wizard menu → switch (persisted under <workspace>/.figma-flutter/workspace-state.yml)
# FIGMA_FLUTTER_PROJECT_DIR=E:/@dev

# Flutter SDK root when `flutter` is not on PATH (common with VS Code tasks on Windows).
# Same path as VS Code "dart.flutterSdkPath" — folder that contains bin/flutter.bat
# FIGMA_FLUTTER_SDK=C:/src/flutter

# Set to 1 to keep hung ast_compiler / sidecar dart processes after killing the terminal
# FIGMA_FLUTTER_SKIP_STALE_CLEANUP=1

# Optional: live-check + pytest -m live_figma (frame from your design URL)
# One-shot (prints values to paste below):
#   poetry run figma-flutter live-check --figma-url "https://www.figma.com/design/<FILE_KEY>/...?node-id=1-2"
# URL node-id 1-2 -> FIGMA_SMOKE_NODE_ID=1:2 (colon, not hyphen)
FIGMA_SMOKE_FILE_KEY=
FIGMA_SMOKE_NODE_ID=

# Optional default Figma URL for wizard prompts (file link or frame link with node-id).
# Falls back after screens.yaml; Enter accepts the shown default.
# FIGMA_DEFAULT_URL=https://www.figma.com/design/<FILE_KEY>/...?node-id=1-2

# Agent behavior YAML lives in the figma-flutter-agent repo (`.ai-figma-flutter.yml`).
# Copy from `.ai-figma-flutter.yml.example` on first setup — not in the Flutter project.

# Discord control plane (optional): copy `.discord-bot.yml.example` → `.discord-bot.yml`
# DISCORD_BOT_TOKEN=
# GITLAB_PRIVATE_TOKEN=
# DISCORD_BOT_CONFIG=
# DISCORD_BOT_DB_PATH=
# DISCORD_BOT_INTERNAL_SECRET=
# DISCORD_BOT_GITLAB_WEBHOOK_SECRET=

# Active LLM provider: anthropic | openai | openrouter | google | google_aistudio
# google / google_aistudio → Gemini via Google AI Studio (GOOGLE_API_KEY)
LLM_PROVIDER=anthropic

# Model IDs (optional; else provider default). Repair/refine inherit generate when unset.
# Any OpenRouter/Anthropic/OpenAI model slug works.
# LLM_GENERATE_MODEL=claude-sonnet-4-6 | gpt-4.1-mini | google/gemini-3.5-flash
# LLM_REPAIR_MODEL=   # optional override; defaults to LLM_GENERATE_MODEL
# LLM_REFINE_MODEL=
LLM_GENERATE_MODEL=
LLM_REPAIR_MODEL=
LLM_REFINE_MODEL=

# Sampling and structured output (technical LLM params — not in YAML)
# Generate: with reasoning on, model vendors often recommend ~1.0; omit to use provider default.
LLM_TEMPERATURE=1
# Repair: keep low for deterministic unified-diff patches (independent of generate).
LLM_REPAIR_TEMPERATURE=0.2
LLM_TOP_P=1
LLM_REQUIRE_STRICT_JSON_SCHEMA=false
# Transient API failures (429/5xx, invalid JSON); default 3
LLM_MAX_RETRIES=3

# Optional reasoning/thinking (generate, repair, refine). Invalid values are dropped.
# On timeout or provider rejection, the client retries without reasoning for that session.
# effort: none | minimal | low | medium | high | xhigh — omit to use provider default
# max_tokens: Anthropic/Gemini 2.5-style budget; do not set both effort and max_tokens
# exclude: true hides reasoning tokens from the response (model may still reason)
# LLM_MAX_OUTPUT_TOKENS=16384  # completion budget; auto +16k headroom when reasoning effort is on
# LLM_REASONING_EFFORT=medium
# LLM_REASONING_MAX_TOKENS=
# LLM_REASONING_EXCLUDE=true

ANTHROPIC_API_KEY=sk-ant-your_api_key
# Google AI Studio: https://aistudio.google.com/apikey (not the same as Vertex service account)
GOOGLE_API_KEY=your_google_ai_studio_api_key
OPENAI_API_KEY=sk-your_openai_api_key
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_api_key

# Optional PostHog LLM analytics (one $ai_trace_id per run; spans: generate, repair, refine)
# POSTHOG_API_KEY=phc_your_project_api_key
# POSTHOG_HOST=https://us.i.posthog.com
# POSTHOG_CAPTURE_MAX_ATTEMPTS=3
# POSTHOG_CAPTURE_TIMEOUT_SEC=8
# POSTHOG_CAPTURE_RETRY_BASE_SEC=0.75

# Optional Grafana Loki log shipping (JSON lines with run_id / stage in extra)
# LOKI_ENABLED=false
# LOKI_URL=https://logs-prod-xxx.grafana.net
# LOKI_USER=123456
# LOKI_API_KEY=glc_xxx
# LOKI_LABELS=env=dev,team=celestial
# LOKI_BATCH_SIZE=64
# LOKI_FLUSH_INTERVAL_SEC=2
# LOKI_PUSH_MAX_ATTEMPTS=3
# LOKI_PUSH_TIMEOUT_SEC=8
# LOKI_PUSH_RETRY_BASE_SEC=0.75
