# =============================================================================
# VPS production — copy to repo root as .env and fill secrets.
# See deploy/README.md for full bootstrap.
# =============================================================================

# --- Public URL (GitLab/Telegram webhooks, preview links) ---
FIGMA_CP_PUBLIC_HOST=cp.example.com
FIGMA_CP_INTERNAL_URL=https://cp.example.com
FIGMA_CP_TLS_EMAIL=ops@example.com

# --- Database (bundled Postgres in Docker; use external for managed DB) ---
FIGMA_CP_DATABASE_MODE=bundled
FIGMA_CP_PG_PASSWORD=change-me-strong-password
# FIGMA_CP_DATABASE_URL=postgresql+asyncpg://user:pass@db.example.com:5432/figma_control_plane

# --- Persistent data on the VPS host ---
FIGMA_CP_PGDATA=./.data/postgres
FIGMA_CP_REDISDATA=./.data/redis
FIGMA_CP_WORKSPACE=./.data/workspace
FIGMA_CP_REPAIR_WORKTREES=./.data/repair-worktrees
# FIGMA_CP_DEPLOY_DIR=/opt/figma-cp

# --- Figma + LLM (required for /generate jobs) ---
FIGMA_ACCESS_TOKEN=
GOOGLE_API_KEY=
LLM_PROVIDER=google
LLM_GENERATE_MODEL=

# --- GitLab Issue workflow (primary headless path) ---
GITLAB_PRIVATE_TOKEN=
CONTROL_PANEL_GITLAB_WEBHOOK_SECRET=

# --- Optional: Discord bot (embedded in control-panel container) ---
# DISCORD_BOT_TOKEN=

# --- Optional: public REST API ---
# CONTROL_PANEL_API_ENABLED=1
# CONTROL_PANEL_API_CLIENTS=[{"principal":"ci-bot","key_hash":"<sha256>","project_key":"default","active_repo_key":"mobile-app"}]

# --- Optional: GitHub publish ---
# GITHUB_TOKEN=

# --- Optional: Telegram ---
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_WEBHOOK_SECRET=

# --- Optional: metrics scrape protection ---
# CONTROL_PANEL_METRICS_TOKEN=

# --- Optional: repair profile (--profile repair) ---
# OPENCODE_SERVER_PASSWORD=
# OPENROUTER_API_KEY=
# REPAIR_OPENCODE_URL=http://opencode:4096

# --- Optional: PostHog business events ---
# POSTHOG_API_KEY=
# POSTHOG_HOST=https://us.i.posthog.com
