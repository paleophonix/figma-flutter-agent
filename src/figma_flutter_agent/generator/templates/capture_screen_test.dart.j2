void main() {
  testWidgets('capture {{ screen_class }}', (tester) async {
    await tester.binding.setSurfaceSize(
      const Size({{ surface_width }}, {{ surface_height }}),
    );

    await tester.pumpWidget(
      MaterialApp(
        theme: AppTheme.light(maxWebWidth: {{ max_web_width }}),
        builder: (context, child) {
          return MediaQuery(
            data: MediaQuery.of(context).copyWith(disableAnimations: true),
            child: child!,
          );
        },
        home: const RepaintBoundary(
          key: ValueKey('figma-capture-root'),
          child: {{ screen_class }}(),
        ),
      ),
    );
    await tester.pump();
    await tester.pump(const Duration(milliseconds: 400));
    await tester.pump(const Duration(milliseconds: 500));

    final outPath = Platform.environment['FIGMA_FLUTTER_CAPTURE_OUT'];
    if (outPath == null || outPath.isEmpty) {
      fail('FIGMA_FLUTTER_CAPTURE_OUT is not set');
    }

    final boundary = tester.renderObject<RenderRepaintBoundary>(
      find.byKey(const ValueKey('figma-capture-root')),
    );
    final pngBytes = await tester.runAsync(() async {
      final image = await boundary.toImage(pixelRatio: 1.0);
      final byteData = await image.toByteData(format: ImageByteFormat.png);
      if (byteData == null) {
        fail('PNG encode failed');
      }
      return byteData.buffer.asUint8List();
    });
    if (pngBytes == null) {
      fail('PNG encode did not complete');
    }
    await File(outPath).writeAsBytes(pngBytes);

{% if collect_figma_keys %}
    final keysPath = Platform.environment['FIGMA_FLUTTER_CAPTURE_KEYS_OUT'];
    if (keysPath != null && keysPath.isNotEmpty) {
      final mapper = UIGeometryMapper(tester);
      final bounds = mapper.collectFigmaKeyBounds({{ screen_class }});
      final payload = <String, dynamic>{};
      for (final entry in bounds.entries) {
        payload[entry.key] = entry.value.toJson();
      }
      await File(keysPath).writeAsString(jsonEncode(payload));
    }
{% endif %}
  });
}
