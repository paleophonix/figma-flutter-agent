discord:
  guild_ids: []
  changelog_channel_id: 1234567890123456789
  access:
    mode: everyone
    allowed_role_ids: []
    allowed_user_ids: []

projects:
  workspace_root: /workspace
  default_user_key: default
  users:
    "123456789012345678":
      project_key: default
      gitlab_username: your_gitlab_username
      active_repo_key: mobile-app
  repos:
    mobile-app:
      provider: github
      remote: org/mobile-app
      github_repo: org/mobile-app
      target_branch: main
      lib_root: lib
      pubspec_path: pubspec.yaml
      bot_push: true

gitlab:
  base_url: https://gitlab.com
  app_project_id: "your_app_project_id"
  artifacts_project_id: "your_artifacts_project_id"
  target_branch: main
  pr_strategy: branch_mr
  source_branch_template: "generate/{job_id}"
  assignee_username: your_gitlab_username
  boss_reviewer_username: boss_username

publish:
  custom_code_policy: preserve_custom
  pr_strategy: update_open
  source_branch_template: "figma/{feature_slug}"
  assignee_username: your_gitlab_username
  boss_reviewer_username: boss_username

preview:
  companion_scheme: figma-flutter
  token_ttl_sec: 3600
  static_port_base: 17357
  adaptive_port_base: 17358

internal:
  callback_secret: ""
  webhook_bind: "0.0.0.0:8787"
  control_plane_url: "http://control-plane:8787"

artifacts:
  remote: "your_org/figma-artifacts"

feedback:
  priority_labels:
    total_mess: ["priority::high", "P1"]
    major_wrong: ["priority::medium", "P2"]
    minor_wrong: ["priority::low", "P3"]

telegram:
  channels:
    team-a:
      chat_id: "-1001234567890"
      invite_link: "https://t.me/+your_invite_hash"

# PostgreSQL: bundled (Docker profile bundled-db) or external (managed/VPS).
database:
  mode: bundled
  bundled_host: postgres
  bundled_port: 5432
  user: figma_cp
  database: figma_control_plane
  # external example (set mode: external and fill url):
  # url: postgresql+asyncpg://user:pass@db.example.com:5432/figma_control_plane
